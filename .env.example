# Copy to `.env` and restart Expo (`npm start`).
# Project URL & anon key: Supabase Dashboard → Settings → API.
#
# Schema: the app does not run SQL. Apply supabase/migrations/*.sql to this project first
# (Dashboard SQL Editor or `npm run db:push` after `supabase link`). See docs/SUPABASE_SETUP.md.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional but required for email confirmation / magic links to open the app (not localhost):
# Must match Authentication → URL Configuration → Redirect URLs in Supabase.
# Example dev build: tap:///auth/callback  OR  exp://YOUR_LAN_IP:8081/--/auth/callback
# EXPO_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=tap:///auth/callback
